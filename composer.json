{
    "name": "mpietrucha/support",
    "description": "The support package.",
    "license": "MIT",
    "type": "library",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Michał Pietrucha",
            "email": "michal.pietrucha@off-site.pl"
        }
    ],
    "require": {
        "php": "^8.5",
        "composer-runtime-api": "^2.2",
        "illuminate/support": "^12.54",
        "laravel/serializable-closure": "^2.0",
        "spatie/invade": "^2.1",
        "symfony/filesystem": "^8.0",
        "symfony/finder": "^7.4",
        "symfony/intl": "^8.0",
        "symfony/process": "^7.4"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.50",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.09",
        "phpstan/phpstan": "^2.1",
        "symfony/var-dumper": "^7.4"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Mpietrucha\\PHPStan\\": "phpstan/src/",
            "Mpietrucha\\Support\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-update-cmd": [
            "@composer normalize"
        ],
        "lint": "pint --verbose",
        "prettier:config": "curl -sSLO https://raw.githubusercontent.com/mpietrucha/prettier/refs/heads/main/dist/.prettierrc",
        "test": [
            "@test:lint",
            "@test:types"
        ],
        "test:lint": "@lint --test",
        "test:types": "phpstan analyse --ansi"
    },
    "$schema": "https://getcomposer.org/schema.json"
}
